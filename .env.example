# Google Cloud / Vertex Gemini
GOOGLE_CLOUD_PROJECT=gd-gcp-gridu-genai
VERTEX_LOCATION=europe-west4
GEMINI_MODEL=gemini-2.0-flash

# Optional: Gemini Developer API (AI Studio). Loaded into Settings and copied to GOOGLE_API_KEY
# when present so ADK/google-genai can authenticate without Vertex ADC on public model names.
# GEMINI_API_KEY=
# Alternative name Google documents for the same value:
# GOOGLE_API_KEY=

# Embeddings → FAISS dimension (aliases: EMBEDDING_DIMENSION or legacy FAISS_EMBEDDING_DIMENSION)
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=768

# Langfuse (optional — self-hosted or cloud SaaS endpoint)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Phase 3 — MCP reference fetch server + Yahoo presets (financial_markets_mcp_tool.py)
# Default **`python`** (matches Settings + Dockerfile extras). Prefer **`docker`** / **`uvx`** only when
# that binary exists on PATH (bare-metal dev). `docker compose` **`rag-ui`** pins **`python`** so
# a host `.env` `docker` value cannot break MCP inside the image.
# MCP_FINANCIAL_FETCH_TRANSPORT=python
# MCP_FINANCIAL_FETCH_TRANSPORT=docker
# MCP_FINANCIAL_DOCKER_IMAGE=mcp/fetch

# Phase 5 — A2A News Agent (standalone service) + orchestrator delegation URLs
#
# **`docker compose`** (collaboration profile) overrides both services so inbound A2A works on the
# bridge network regardless of `.env`:
# • `news-agent` → **`NEWS_AGENT_PUBLIC_BASE_URL=http://news-agent:8090`** (URLs inside agent-card
#   JSON must match this; **`http://localhost:8090`** in `.env` would break follow-up RPC from **`rag-ui`**).
# • `rag-ui` → **`NEWS_AGENT_A2A_BASE_URL=http://news-agent:8090`** always.
#
# Streamlit-only on your laptop (no Compose UI): callers use **published** ports:
#     NEWS_AGENT_A2A_BASE_URL=http://localhost:8090
#     NEWS_AGENT_PUBLIC_BASE_URL=http://localhost:8090
#
# Langfuse in **`rag-ui`**: `LANGFUSE_HOST=http://localhost:3000` in `.env` points at the container
# itself — use **`LANGFUSE_HOST=http://host.docker.internal:3000`** (Docker Desktop) or omit keys.
