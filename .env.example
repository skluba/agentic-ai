# Google Cloud / Vertex Gemini
GOOGLE_CLOUD_PROJECT=gd-gcp-gridu-genai
VERTEX_LOCATION=europe-west4
GEMINI_MODEL=gemini-2.0-flash

# Optional: Gemini Developer API (AI Studio). Loaded into Settings and copied to GOOGLE_API_KEY
# when present so ADK/google-genai can authenticate without Vertex ADC on public model names.
# GEMINI_API_KEY=
# Alternative name Google documents for the same value:
# GOOGLE_API_KEY=

# Embeddings → FAISS dimension (aliases: EMBEDDING_DIMENSION or legacy FAISS_EMBEDDING_DIMENSION)
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=768

# Langfuse (optional — self-hosted or cloud SaaS endpoint)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Phase 3 — MCP reference fetch server + Yahoo presets (financial_markets_mcp_tool.py)
# docker | uvx | python   (python / container image installs optional `pip install '.[phase3-fetch]'`)
# MCP_FINANCIAL_FETCH_TRANSPORT=docker
# MCP_FINANCIAL_DOCKER_IMAGE=mcp/fetch

# Phase 5 — A2A News Agent (standalone service) + orchestrator delegation URLs
# Public URL advertised in /.well-known/agent-card.json must match callers' reachable base (`http://host:8090`).
# NEWS_AGENT_PUBLIC_BASE_URL=http://localhost:8090
#
# NEWS_AGENT_A2A_BASE_URL=http://localhost:8090
# NEWS_AGENT_USE_OFFLINE_EMBEDDINGS=true
# NEWS_AGENT_HTTP_TIMEOUT_SECONDS=120
